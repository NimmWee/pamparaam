COMPOSE_PROJECT_NAME=wiki-editor
GO_VERSION=1.23.0
LOG_LEVEL=INFO

GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
AUTH_SERVICE_GRPC_PORT=9091
PAGE_SERVICE_PORT=8082
PAGE_SERVICE_GRPC_PORT=9092
COLLABORATION_SERVICE_PORT=8083
SEARCH_SERVICE_PORT=8084
MWS_INTEGRATION_SERVICE_PORT=8085
MWS_INTEGRATION_SERVICE_GRPC_PORT=9095
FILE_SERVICE_PORT=8086
FILE_SERVICE_GRPC_PORT=9096
MWS_MOCK_PORT=8090
PROMETHEUS_PORT=9090

AUTH_DB_PORT=5432
PAGE_DB_PORT=5433
SEARCH_DB_PORT=5434
FILE_DB_PORT=5435
POSTGRES_USER=wiki
POSTGRES_PASSWORD=wiki
POSTGRES_DB_AUTH=wiki_auth
POSTGRES_DB_PAGE=wiki_page
POSTGRES_DB_SEARCH=wiki_search
POSTGRES_DB_FILE=wiki_file

AUTH_DATABASE_URL=postgres://wiki:wiki@postgres-auth:5432/wiki_auth?sslmode=disable
PAGE_DATABASE_URL=postgres://wiki:wiki@postgres-page:5432/wiki_page?sslmode=disable
SEARCH_DATABASE_URL=postgres://wiki:wiki@postgres-search:5432/wiki_search?sslmode=disable
FILE_DATABASE_URL=postgres://wiki:wiki@postgres-file:5432/wiki_file?sslmode=disable

REDIS_ADDR=redis:6379
REDIS_DB=0
NATS_URL=nats://nats:4222
PAGE_REDIS_ADDR=redis:6379
PAGE_REDIS_DB=0
COLLABORATION_REDIS_ADDR=redis:6379
COLLABORATION_REDIS_DB=0
PAGE_NATS_URL=nats://nats:4222
SEARCH_NATS_URL=nats://nats:4222
COLLABORATION_NATS_URL=nats://nats:4222

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_ATTACHMENTS=wiki-attachments
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false
FILE_MINIO_ENDPOINT=minio:9000
FILE_MINIO_PUBLIC_BASE_URL=http://localhost:9000
FILE_MINIO_ACCESS_KEY_ID=minioadmin
FILE_MINIO_SECRET_ACCESS_KEY=minioadmin
FILE_MINIO_BUCKET=wiki-attachments
FILE_MINIO_USE_SSL=false

JWT_ISSUER=wiki-auth
JWT_AUDIENCE=wiki-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
AUTH_SERVICE_JWKS_CACHE_TTL=5m
AUTH_SERVICE_GRPC_ADDR=auth-service:9091
PAGE_SERVICE_GRPC_ADDR=page-service:9092
MWS_INTEGRATION_SERVICE_GRPC_ADDR=mws-integration-service:9095
FILE_SERVICE_GRPC_ADDR=file-service:9096

AUTH_SERVICE_BASE_URL=http://auth-service:8081
AUTH_SERVICE_READY_URL=http://auth-service:8081/health/ready
AUTH_SERVICE_JWKS_URL=http://auth-service:8081/.well-known/jwks.json
PAGE_SERVICE_BASE_URL=http://page-service:8082
COLLABORATION_SERVICE_BASE_URL=http://collaboration-service:8083
SEARCH_SERVICE_BASE_URL=http://knowledge-graph-search-service:8084
MWS_INTEGRATION_SERVICE_BASE_URL=http://mws-integration-service:8085
FILE_SERVICE_BASE_URL=http://file-service:8086
GATEWAY_OPENAPI_PATH=/app/specs/001-wiki-editor-backend/contracts/public-api.openapi.yaml

MWS_BASE_URL=http://mws-mock:8090
MWS_MOCK_BASE_URL=http://mws-mock:8090
